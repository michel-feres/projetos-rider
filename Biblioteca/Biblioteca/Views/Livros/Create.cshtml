@model Biblioteca.Models.Livro

@{
    ViewData["Title"] = "Cadastrar livro";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h1 class="h3 mb-3">Cadastrar livro</h1>
                <p class="text-muted">Preencha os campos obrigatórios para incluir um livro no acervo.</p>
                <partial name="_Form" model="Model" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
