@model IEnumerable<Biblioteca.Models.Emprestimo>

@{
    ViewData["Title"] = ViewBag.TituloPagina ?? "Empréstimos";
    var pagina = ViewBag.Pagina as int? ?? 1;
    var totalPaginas = ViewBag.TotalPaginas as int? ?? 1;
    var actionName = ViewBag.ActionName as string ?? "Index";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="mb-1">@ViewData["Title"]</h1>
        <p class="text-muted mb-0">Registre empréstimos, devoluções, atrasos e multas.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Novo empréstimo</a>
</div>

@if (TempData["MensagemSucesso"] is not null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["MensagemSucesso"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
    </div>
}

<form method="get" class="card shadow-sm mb-3">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label" for="usuarioId">Usuário</label>
                <select id="usuarioId" name="usuarioId" asp-items="ViewBag.UsuariosFiltro" class="form-select">
                    <option value="">Todos</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label" for="status">Status</label>
                <select id="status" name="status" class="form-select">
                    <option value="">Todos</option>
                    @foreach (var item in new[] { "Emprestado", "Atrasado", "Devolvido" })
                    {
                        if (ViewBag.StatusFiltro == item)
                        {
                            <option value="@item" selected>@item</option>
                        }
                        else
                        {
                            <option value="@item">@item</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Filtrar</button>
                <a class="btn btn-outline-secondary" asp-action="Index">Limpar</a>
                <a class="btn btn-outline-primary" asp-action="Historico">Histórico por usuário</a>
            </div>
        </div>
    </div>
</form>

<div class="card shadow-sm">
    <div class="card-body table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
            <tr>
                <th>@Html.DisplayNameFor(model => model.Usuario)</th>
                <th>@Html.DisplayNameFor(model => model.Livro)</th>
                <th>@Html.DisplayNameFor(model => model.DataEmprestimo)</th>
                <th>@Html.DisplayNameFor(model => model.DataPrevistaDevolucao)</th>
                <th>@Html.DisplayNameFor(model => model.DataDevolucao)</th>
                <th>@Html.DisplayNameFor(model => model.DiasAtraso)</th>
                <th>@Html.DisplayNameFor(model => model.Multa)</th>
                <th>@Html.DisplayNameFor(model => model.Status)</th>
                <th class="text-end">Ações</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var emprestimo in Model)
            {
                <tr>
                    <td>@emprestimo.Usuario?.NomeCompleto</td>
                    <td>@emprestimo.Livro?.Titulo</td>
                    <td>@emprestimo.DataEmprestimo.ToString("dd/MM/yyyy")</td>
                    <td>@emprestimo.DataPrevistaDevolucao.ToString("dd/MM/yyyy")</td>
                    <td>@(emprestimo.DataDevolucao?.ToString("dd/MM/yyyy") ?? "-")</td>
                    <td>@emprestimo.DiasAtraso</td>
                    <td>@emprestimo.MultaAtual.ToString("C")</td>
                    <td>
                        <span class="badge @(emprestimo.Status == "Atrasado" ? "text-bg-danger" : emprestimo.Status == "Devolvido" ? "text-bg-secondary" : "text-bg-success")">@emprestimo.Status</span>
                    </td>
                    <td class="text-end">
                        <div class="btn-group" role="group" aria-label="Ações do empréstimo">
                            @if (!emprestimo.DataDevolucao.HasValue)
                            {
                                <a class="btn btn-sm btn-outline-success" asp-action="Devolver" asp-route-id="@emprestimo.Id">Devolver</a>
                            }
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@emprestimo.Id">Editar</a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@emprestimo.Id">Excluir</a>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>

        @if (!Model.Any())
        {
            <div class="text-center text-muted py-4">
                Nenhum empréstimo cadastrado ainda.
            </div>
        }
    </div>
</div>

@if (totalPaginas > 1)
{
    <nav class="mt-3" aria-label="Paginação de empréstimos">
        <ul class="pagination justify-content-end">
            @for (var item = 1; item <= totalPaginas; item++)
            {
                <li class="page-item @(item == pagina ? "active" : "")">
                    <a class="page-link" asp-action="@actionName" asp-route-usuarioId="@ViewBag.UsuarioId" asp-route-status="@ViewBag.StatusFiltro" asp-route-pagina="@item">@item</a>
                </li>
            }
        </ul>
    </nav>
}
