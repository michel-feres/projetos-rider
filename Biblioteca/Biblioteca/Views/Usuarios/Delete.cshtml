@model Biblioteca.Models.Usuario

@{
    ViewData["Title"] = "Excluir usuário";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm border-danger">
            <div class="card-body p-4">
                <h1 class="h3 mb-3 text-danger">Excluir usuário</h1>
                <p>Tem certeza que deseja excluir este usuário?</p>

                <dl class="row">
                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.NomeCompleto)</dt>
                    <dd class="col-sm-8">@Model.NomeCompleto</dd>
                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Email)</dt>
                    <dd class="col-sm-8">@Model.Email</dd>
                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Status)</dt>
                    <dd class="col-sm-8">@Model.Status</dd>
                </dl>

                <form asp-action="Delete" method="post" class="d-flex gap-2">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger">Confirmar exclusão</button>
                    <a class="btn btn-outline-secondary" asp-action="Index">Cancelar</a>
                </form>
            </div>
        </div>
    </div>
</div>