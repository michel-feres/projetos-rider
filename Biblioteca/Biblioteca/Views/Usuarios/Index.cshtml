@model IEnumerable<Biblioteca.Models.Usuario>

@{
    ViewData["Title"] = "Usuários";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="mb-1">Usuários</h1>
        <p class="text-muted mb-0">Cadastre, edite, liste e exclua usuários da biblioteca.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Novo usuário</a>
</div>

@if (TempData["MensagemSucesso"] is not null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["MensagemSucesso"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
    </div>
}

@if (TempData["MensagemErro"] is not null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["MensagemErro"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
            <tr>
                <th>@Html.DisplayNameFor(model => model.NomeCompleto)</th>
                <th>@Html.DisplayNameFor(model => model.Email)</th>
                <th>@Html.DisplayNameFor(model => model.DataNascimento)</th>
                <th>Idade</th>
                <th>@Html.DisplayNameFor(model => model.Status)</th>
                <th class="text-end">Ações</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var usuario in Model)
            {
                <tr>
                    <td>@usuario.NomeCompleto</td>
                    <td>@usuario.Email</td>
                    <td>@usuario.DataNascimento.ToString("dd/MM/yyyy")</td>
                    <td>@usuario.Idade anos</td>
                    <td>
                        <span class="badge @(usuario.Ativo ? "text-bg-success" : "text-bg-secondary")">@usuario.Status</span>
                    </td>
                    <td class="text-end">
                        <div class="btn-group" role="group" aria-label="Ações do usuário">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@usuario.Id">Editar</a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@usuario.Id">Excluir</a>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>

        @if (!Model.Any())
        {
            <div class="text-center text-muted py-4">
                Nenhum usuário cadastrado ainda.
            </div>
        }
    </div>
</div>
