@model CrudFornecedorProduto.Models.Produto

@{
    ViewData["Title"] = "Create";
}

@*
    View Create (Criar Produto)
    - Esta view exibe um formulário para criação de um produto.
    - Usamos tag helpers (asp-for, asp-action, asp-items) que facilitam
      o binding entre view e model/controller.
*@
<h1>Create</h1>

<h4>Produto</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        @* Formulário enviado para a action Create do controller *@
        <form asp-action="Create">
            @* Mostra erros de validação do model, se existirem *@
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                @* label e input para Nome (asp-for liga ao Model.Nome) *@
                <label asp-for="Nome" class="control-label"></label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>
            <div class="form-group">
                @* Valor: usamos type="text" para permitir vírgula no client;
                   a validação cultural e o model binder no servidor tratam a conversão. *@
                <label asp-for="Valor" class="control-label"></label>
                <input asp-for="Valor" class="form-control" type="text" />
                <span asp-validation-for="Valor" class="text-danger"></span>
            </div>
            <div class="form-group">
                @* Combobox de Fornecedores: asp-items popula as options a partir de ViewBag.FornecedorId *@
                <label asp-for="FornecedorId" class="control-label"></label>
                <select asp-for="FornecedorId" class ="form-control" asp-items="ViewBag.FornecedorId"></select>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @* Carrega scripts de validação (unobtrusive/jQuery Validate) *@
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
