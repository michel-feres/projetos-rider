@model CrudFornecedorProduto.Models.Produto

@{
    ViewData["Title"] = "Edit";
}

@*
    View Edit (Editar Produto)
    - Exibe o formulário com os dados do produto para edição.
    - O campo ProdutoId é enviado como hidden para identificar a entidade.
    - Valor está como text para permitir entrada com vírgula; a validação
      client-side e o model binder cuidam da conversão para decimal.
*@
<h1>Edit</h1>

<h4>Produto</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            @* Mostra somente erros relacionados ao model *@
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            @* Campo oculto com o id do produto (necessário para o post) *@
            <input type="hidden" asp-for="ProdutoId" />
            <div class="form-group">
                <label asp-for="Nome" class="control-label"></label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Valor" class="control-label"></label>
                <input asp-for="Valor" class="form-control" type="text" />
                <span asp-validation-for="Valor" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FornecedorId" class="control-label"></label>
                <select asp-for="FornecedorId" class="form-control" asp-items="ViewBag.FornecedorId"></select>
                <span asp-validation-for="FornecedorId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
