@model CrudFornecedorProduto.Models.Fornecedor

@{
    ViewData["Title"] = "Details";
}

@*
    View Details para Fornecedor
    - Mostra informações detalhadas de um fornecedor específico.
    - Usa definition list (dl/dt/dd) para apresentar labels e valores de forma clara.
    - Há links para editar o fornecedor ou voltar à lista.
*@
<h1>Details</h1>

<div>
    <h4>Fornecedor</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Nome)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Nome)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Cidade)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Cidade)
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.FornecedorId">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
