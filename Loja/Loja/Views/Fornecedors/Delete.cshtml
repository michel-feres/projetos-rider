@model CrudProdutoFornecedor.Models.Fornecedor

@{
    ViewData["Title"] = "Delete";
}

@*
    View Delete para Fornecedor
    - Exibe confirmação antes de remover um fornecedor do sistema.
    - Mostra os principais campos do fornecedor para que o usuário
      confirme que está excluindo o registro correto.
    - O formulário submete a ação Delete (POST) com o id em hidden.
*@
<h1>Delete</h1>

<h3>Tem certeza que deseja excluir este fornecedor?</h3>
<div>
    <h4>Fornecedor</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Nome)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Nome)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Cidade)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Cidade)
        </dd>
    </dl>

    <form asp-action="Delete">
        @* Envia o id do fornecedor para a action Delete (POST) *@
        <input type="hidden" asp-for="FornecedorId" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index">Back to List</a>
    </form>
</div>
